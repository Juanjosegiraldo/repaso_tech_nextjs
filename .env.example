# Copy this file as .env.local and replace the values.

# --- MongoDB Atlas ---
# If your network blocks SRV DNS (mongodb+srv://), use the standard string (no +srv):
# mongodb://USER:PASS@host1:27017,host2:27017,host3:27017/DBNAME?ssl=true&replicaSet=...&authSource=admin&appName=Cluster0
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/technova?retryWrites=true&w=majority

# --- Mail (notifications phase) ---
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-gmail-app-password
